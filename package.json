{
  "name": "ltx-timeline-harness",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Node.js harness for t2v/i2v V6 timeline CLIs (rewrite of x-post v6_harness_v2.py)",
  "scripts": {
    "postinstall": "npm --prefix studio/client install",
    "studio:start": "node studio/server/index.js",
    "studio:dev": "node --watch studio/server/index.js",
    "studio:build": "npm --prefix studio/client run build"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0"
  }
}
