# LTX Timeline Harness .env — このファイルを .env にコピーして値を埋めること。
# サーバー起動中に編集しても、次のLLM呼び出し・生成subprocessから即反映される(再起動不要)。

# ==== CLIの設定(必須) ====
# プロンプト展開(Pass0〜4)・要約・BGM説明文生成に使うOpenAI互換LLM
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=your-model-name
LLM_API_KEY=

# ==== ComfyUIの設定(必須) ====
# ComfyUIサーバーのURL(画像=キーフレーム生成 / 動画=I2V・T2V・アップスケール)
COMFYUI_IMAGE_URL=http://localhost:8188
COMFYUI_VIDEO_URL=http://localhost:8188

# 動画ワークフロー内LLMノード(node51/52)を上書き。未指定時はLLM_*を流用
# COMFYUI_LLM_BASE_URL=
# COMFYUI_LLM_MODEL=
# COMFYUI_LLM_API_KEY=

# i2vキーフレーム生成のLoRA上書き(名前空=ワークフローの値のまま。強度-1=そのまま、0=キャラLoRA無効化)
# KEYFRAME_LORA_NAME=
# KEYFRAME_LORA_STRENGTH=

# キーフレーム生成に使うComfyUIワークフローJSON(workflows/配下)。デフォルトimage.json
# KEYFRAME_WORKFLOW_JSON=image.json
# キーフレーム解像度の倍率(動画のwidth/heightに掛ける)
# KEYFRAME_SIZE_SCALE=1.0

# 最終連結動画の末尾フェードアウト(映像・音声とも1秒)。デフォルトtrue
# FADE_OUT_ENABLED=true

# i2v/t2vの動画生成に使うComfyUIワークフローJSON(workflows/配下)。デフォルトはどちらもvideo.json
# I2V_VIDEO_ENGINE=default
# T2V_VIDEO_ENGINE=video.json

# 画像プロンプト冒頭に付加する品質向上prefix
# IMAGE_PROMPT_PREFIX=

# ==== CASSの設定(⑤CASSタブのBGM生成機能を使う場合のみ) ====
# ACE-Step-1.5 APIサーバー(別途起動が必要、README参照)
# ACESTEP_URL=http://localhost:8001
# ACESTEP_MODEL=acestep-v15-sft
